[global]
font = "IBM Plex Sans 11"
frame_color = "#90989a"
frame_width = 2
separator_color= frame
highlight = "#89b4fa"
corner_radius = 10

[urgency_low]
background = "#000000"
foreground = "#white"

[urgency_normal]
background = "#000000"
foreground = "#white"

[urgency_critical]
background = "#000000"
foreground = "#white"
frame_color = "#ff0000"
