{
  "custom/empty": {
    "format": ""
  },
  "custom/exit": {
    "exec": "~/.config/waybar/scripts/kw-ram.sh",
    "return-type": "json",
    "interval": 2,
    "tooltip": true,
    "on-click": "hyprlock"
  },
  "group/hardware": {
    "format": "CPU: {cpu} MEM: {memory} DISK: {disk}",
    "interval": 1
  },
  "tray": {
    "icon-size": 16,
    "spacing": 10
  },
  "custom/vpn": {
    "exec": "~/.config/waybar/scripts/vpn.sh",
    "return-type": "json",
    "interval": 3,
    "signal": 8,
    "format": "{}",
    "tooltip": true,
    "on-click": "~/.config/waybar/scripts/vpn-toggle.sh",
    "on-click-right": "foot -e sh -c 'tail -n 200 -f \"${XDG_RUNTIME_DIR:-/tmp}/waybar-vpn/openfortivpn.log\"'"
  },
  "custom/warp": {
    "exec": "~/.config/waybar/scripts/warp.sh",
    "return-type": "json",
    "interval": 3,
    "signal": 9,
    "format": "{}",
    "tooltip": true,
    "on-click": "~/.config/waybar/scripts/warp-toggle.sh",
    "on-click-right": "foot -e sh -c 'warp-cli status; warp-cli settings; echo; read -p \"press enter\"'"
  },
  "clock": {
    "format": "{:%I:%M %A %d/%m}",
    "tooltip-format": "<span size='large' weight='bold'>{:%A, %B %d %Y}</span>\n<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#facc15'><b>{}</b></span>",
        "days": "<span color='#e5e7eb'>{}</span>",
        "weeks": "<span color='#6b7280'><i>W{}</i></span>",
        "weekdays": "<span color='#89ddff'><b>{}</b></span>",
        "today": "<span color='#4ade80'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "cpu": {
    "format": "/ C {usage}% ",
    "on-click": "~/.config/my-scripts/settings/system-monitor.sh"
  },
  "memory": {
    "format": "/ M {}% ",
    "on-click": "~/.config/my-scripts/settings/system-monitor.sh"
  },
  "disk": {
    "interval": 1,
    "format": "D {percentage_used}% ",
    "path": "/",
    "on-click": "~/.config/my-scripts/settings/system-monitor.sh"
  },
  "network": {
    "format": "{ifname}",
    "format-wifi": "{icon}",
    "format-ethernet": "󰈀   Wired",
    "format-disconnected": "󰤮 No Network",
    "format-icons": ["󰤯", "󰤟", "󰤢", "󰤥", "󰤨"],
    "tooltip-format": "󰈀 {ifname} via {gwaddri}",
    "tooltip-format-wifi": "{icon}    {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
    "tooltip-format-ethernet": "󰈀    {ifname}\nIP: {ipaddr}\nup: {bandwidthUpBits} down: {bandwidthDownBits}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "min-length": 2,
    "on-click": "~/.config/my-scripts/settings/networkmanager.sh",
    "on-click-right": "~/.config/my-scripts/settings/networkmanager.sh"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-charging": "󰂄  {capacity}%",
    "format-plugged": "󰚥  {capacity}%",
    "format-icons": ["󰂎", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
    "tooltip-format": "{timeTo}\n{power}W"
  },
  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{icon}  {volume}% 󰂯",
    "format-bluetooth-muted": "󰸈  {volume}% 󰂯",
    "format-muted": "󰸈  {volume}%",
    "format-source": "{volume}% 󰍬",
    "format-source-muted": "󰍭",
    "format-icons": {
      "headphone": "󰋋",
      "hands-free": "󰋎",
      "headset": "󰋎",
      "phone": "󰏲",
      "portable": "󰏲",
      "car": "󰄋",
      "default": ["󰕿", "󰖀", "󰕾"]
    },
    "tooltip-format": "{desc} — {volume}%",
    "scroll-step": 5,
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right": "pavucontrol"
  },
  "bluetooth": {
    "format": "󰂯",
    "format-on": "󰂯",
    "format-off": "󰂲",
    "format-disabled": "󰂲",
    "format-no-controller": "",
    "format-connected": "󰂱 {num_connections}",
    "tooltip-format": "Bluetooth: {status}\nController: {controller_alias}",
    "tooltip-format-connected": "Bluetooth: {status}\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias} ({device_address})",
    "tooltip-format-enumerate-connected-battery": "{device_alias}: {device_battery_percentage}%",
    "interval": 30,
    "on-click": "sleep 0.1 && ~/.config/my-scripts/settings/bluetooth.sh"
  },
  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["󰃞", "󰃟", "󰃠"],
    "scroll-step": 1
  }
}
