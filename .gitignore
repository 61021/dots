# ─────────────────────────────────────────────────────────────
# Dotfiles repo: ignore everything in $HOME by default,
# then explicitly allow-list what should be tracked.
# ─────────────────────────────────────────────────────────────
/*
!.gitignore

# ── Top-level dotfiles ───────────────────────────────────────
!.bash_profile
!.bashrc
!.gitconfig
!.gtkrc-2.0
!.gtkrc-2.0.mine
!.xinitrc
!README.md
!install.sh
!packages-repo.txt
!packages-aur.txt

# ── stuff/ (only constants and scripts) ──────────────────────
!stuff/
stuff/*
!stuff/constants
!stuff/scripts

# ── .config/ ─────────────────────────────────────────────────
!.config/
.config/*
!.config/Thunar
!.config/btop
!.config/dunst
!.config/fastfetch
!.config/fish
!.config/flameshot
!.config/fontconfig
!.config/gtk-3.0
!.config/gtk-4.0
!.config/hypr
!.config/kdeglobals
!.config/kitty
!.config/mimeapps.list
!.config/mpv
!.config/nvim
!.config/nwg-displays
!.config/nwg-look
!.config/paru
!.config/qt5ct
!.config/qt6ct
!.config/rofi
!.config/user-dirs.dirs
!.config/waybar
!.config/wofi
!.config/xsettingsd

# ── .local/share/ (fonts only) ───────────────────────────────
!.local/
.local/*
!.local/share/
.local/share/*
!.local/share/fonts

# ─────────────────────────────────────────────────────────────
# Defensive ignores: drop noise inside allow-listed folders
# ─────────────────────────────────────────────────────────────
**/.DS_Store
**/Thumbs.db
**/*.log
**/*.bak
**/*.swp
**/*.swo
**/*~

# fish: per-machine state
.config/fish/fish_history
.config/fish/generated_completions/
.config/fish/.nvimlog

# nvim: caches & state
.config/nvim/.stylua-cache/
.config/nvim/spell/

# paru caches
.config/paru/*.cache
